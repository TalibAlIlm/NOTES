<!-- ═══════════════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════════════ -->
<script>
'use strict';

/* ─────────────────────────────────────────────
   KONFIGURATION
───────────────────────────────────────────── */
const TYPES = {
  ayah:   {
    label:    'Āyah',
    badge:    'Āyah',
    ph:       'Koranvers eingeben …',
    dotColor: '#D4A017',
  },
  hadith: {
    label:    'Hadīth',
    badge:    'Hadīth',
    ph:       'Hadith eingeben …',
    dotColor: '#3AA86A',
  },
  athaar: {
    label:    'Athar / Sharḥ',
    badge:    'Athar',
    ph:       'Gelehrtenaussage / Kommentar …',
    dotColor: '#4A7EC8',
  },
  normal: {
    label:    'Notiz',
    badge:    '',
    ph:       'Eigene Notiz, Erläuterung, Zusammenfassung …',
    dotColor: '#3A3530',
  },
};

/* ─────────────────────────────────────────────
   ZUSTAND
───────────────────────────────────────────── */
let focused  = null;  // aktuell fokussierter .block DOM-Knoten
let blockSeq = 0;

/* ─────────────────────────────────────────────
   DOM-REFERENZEN
───────────────────────────────────────────── */
const docBody   = document.getElementById('doc-body');
const inTitle   = document.getElementById('in-title');
const inAuthor  = document.getElementById('in-author');
const inChapter = document.getElementById('in-chapter');
const docTitle  = document.getElementById('doc-title');
const docAuthor = document.getElementById('doc-author');
const docChap   = document.getElementById('doc-chapter');
const footTitle = document.getElementById('foot-title');
const toastEl   = document.getElementById('toast');
const curDot    = document.getElementById('cur-dot');
const curVal    = document.getElementById('cur-val');

/* ─────────────────────────────────────────────
   SIDEBAR ↔ DOKUMENT SYNCHRONISIERUNG
───────────────────────────────────────────── */
function syncToDoc() {
  docTitle.value  = inTitle.value;
  docAuthor.value = inAuthor.value;
  docChap.value   = inChapter.value;
  footTitle.textContent = inTitle.value || 'Talib al-ʿIlm';
}

inTitle.addEventListener('input',   syncToDoc);
inAuthor.addEventListener('input',  syncToDoc);
inChapter.addEventListener('input', syncToDoc);

// Umgekehrt: Dokument → Sidebar
docTitle.addEventListener('input', () => {
  inTitle.value = docTitle.value;
  footTitle.textContent = docTitle.value || 'Talib al-ʿIlm';
});
docAuthor.addEventListener('input', () => {
  inAuthor.value = docAuthor.value;
});
docChap.addEventListener('input', () => {
  inChapter.value = docChap.value;
});

/* ─────────────────────────────────────────────
   AKTUELLER TYP IN SIDEBAR ANZEIGEN
───────────────────────────────────────────── */
function updateStatusIndicator(type) {
  const cfg = TYPES[type] || TYPES.normal;
  curVal.textContent  = cfg.label;
  curDot.style.background = cfg.dotColor;
}

function clearStatusIndicator() {
  curVal.textContent = '—';
  curDot.style.background = 'var(--sb-border)';
}

/* ─────────────────────────────────────────────
   LEGENDE: AKTIVER ZUSTAND
───────────────────────────────────────────── */
function updateLegendActive(type) {
  document.querySelectorAll('.leg').forEach(l => {
    l.classList.toggle('active', l.dataset.type === type);
  });
}

/* ─────────────────────────────────────────────
   BLOCK ERSTELLEN
───────────────────────────────────────────── */
function mkBlock(type, text) {
  type = type || 'normal';
  blockSeq++;

  const wrap = document.createElement('div');
  wrap.className  = 'block';
  wrap.dataset.type = type;
  wrap.dataset.bid  = blockSeq;

  // Farbiger Balken links
  const bar = document.createElement('div');
  bar.className = 'block-bar';

  // Bearbeitbarer Text-Bereich
  const editor = document.createElement('div');
  editor.className       = 'block-text';
  editor.contentEditable = 'true';
  editor.dir             = 'auto';        // Automatische LTR/RTL-Erkennung
  editor.spellcheck      = true;
  editor.dataset.ph      = TYPES[type].ph;

  if (text && text.trim()) {
    // Zeilenumbrüche in <br>-Elemente umwandeln
    text.split('\n').forEach((line, i) => {
      if (i > 0) editor.appendChild(document.createElement('br'));
      if (line) editor.appendChild(document.createTextNode(line));
    });
  }

  // Werkzeug-Buttons
  const tools = document.createElement('div');
  tools.className = 'block-tools';

  function mkBtn(ico, title, action) {
    const b = document.createElement('button');
    b.className = 'bt';
    b.title     = title;
    b.innerHTML = ico;
    b.addEventListener('mousedown', e => {
      e.preventDefault(); // Verhindert, dass der Block seinen Fokus verliert
      action();
    });
    return b;
  }

  tools.appendChild(mkBtn('↑', 'Nach oben (Shift+↑)',  () => moveBlock(wrap, -1)));
  tools.appendChild(mkBtn('↓', 'Nach unten (Shift+↓)', () => moveBlock(wrap,  1)));
  tools.appendChild(mkBtn('✕', 'Block löschen',          () => removeBlock(wrap)));

  wrap.appendChild(bar);
  wrap.appendChild(editor);
  wrap.appendChild(tools);

  // Fokus-Ereignisse
  editor.addEventListener('focus', () => {
    if (focused && focused !== wrap) {
      focused.classList.remove('is-focused');
    }
    focused = wrap;
    wrap.classList.add('is-focused');
    updateLegendActive(wrap.dataset.type);
    updateStatusIndicator(wrap.dataset.type);
  });

  editor.addEventListener('blur', () => {
    // Leicht verzögert prüfen, ob ein anderer Block Fokus bekommt
    setTimeout(() => {
      if (focused === wrap) {
        wrap.classList.remove('is-focused');
        focused = null;
        clearStatusIndicator();
        document.querySelectorAll('.leg').forEach(l => l.classList.remove('active'));
      }
    }, 80);
  });

  // Tastatureingaben im Block
  editor.addEventListener('keydown', e => onKey(e, wrap));

  return wrap;
}

/* ─────────────────────────────────────────────
   BLOCK EINFÜGEN
───────────────────────────────────────────── */
function insertBlock(type, text, after) {
  const b = mkBlock(type, text || '');
  if (after) {
    after.insertAdjacentElement('afterend', b);
  } else {
    docBody.appendChild(b);
  }
  return b;
}

/* ─────────────────────────────────────────────
   BLOCK FOKUSSIEREN (Cursor ans Ende)
───────────────────────────────────────────── */
function focusBlock(block) {
  const ed = block.querySelector('.block-text');
  ed.focus();
  caretToEnd(ed);
}

/* ─────────────────────────────────────────────
   BLOCK LÖSCHEN
───────────────────────────────────────────── */
function removeBlock(block) {
  const all = [...docBody.querySelectorAll('.block')];

  if (all.length <= 1) {
    // Letzten Block nicht löschen, nur leeren und auf normal zurücksetzen
    const ed = block.querySelector('.block-text');
    ed.innerHTML = '';
    setType(block, 'normal');
    ed.focus();
    return;
  }

  const idx = all.indexOf(block);
  block.remove();

  const remaining = [...docBody.querySelectorAll('.block')];
  const target    = remaining[Math.max(0, idx - 1)];
  if (target) focusBlock(target);
}

/* ─────────────────────────────────────────────
   BLOCK VERSCHIEBEN
───────────────────────────────────────────── */
function moveBlock(block, dir) {
  const all = [...docBody.querySelectorAll('.block')];
  const i   = all.indexOf(block);

  if (dir === -1 && i > 0) {
    // Nach oben: vor den Vorgänger einsetzen
    docBody.insertBefore(block, all[i - 1]);
  } else if (dir === 1 && i < all.length - 1) {
    // Nach unten: nach dem Nachfolger einsetzen
    all[i + 1].insertAdjacentElement('afterend', block);
  }

  focusBlock(block);
}

/* ─────────────────────────────────────────────
   BLOCKTYP SETZEN
───────────────────────────────────────────── */
function setType(block, type) {
  if (!TYPES[type]) return;
  block.dataset.type = type;

  const ed = block.querySelector('.block-text');
  ed.dataset.ph = TYPES[type].ph;

  updateLegendActive(type);
  updateStatusIndicator(type);
  showToast('→ ' + TYPES[type].label);
}

/* ─────────────────────────────────────────────
   TASTATUREINGABEN IN EINEM BLOCK
───────────────────────────────────────────── */
function onKey(e, block) {
  const ed = e.target;

  // Alt+0-3 oder Ctrl+0-3 → Blocktyp ändern
  if (e.altKey || e.ctrlKey) {
    const typeMap = { '0': 'normal', '1': 'ayah', '2': 'hadith', '3': 'athaar' };
    if (typeMap[e.key] !== undefined) {
      e.preventDefault();
      setType(block, typeMap[e.key]);
      return;
    }
  }

  // Enter (ohne Shift) → neuen Block nach diesem erstellen
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    const nb = insertBlock('normal', '', block);
    focusBlock(nb);
    return;
  }

  // Backspace auf leerem Block → Block löschen
  if (e.key === 'Backspace') {
    if (isEditorEmpty(ed)) {
      e.preventDefault();
      removeBlock(block);
      return;
    }
  }

  // Shift+Pfeil-Oben/Unten → Block verschieben
  if (e.shiftKey) {
    if (e.key === 'ArrowUp')   { e.preventDefault(); moveBlock(block, -1); return; }
    if (e.key === 'ArrowDown') { e.preventDefault(); moveBlock(block,  1); return; }
  }
}

/* Hilfsfunktion: Ist ein contenteditable leer? */
function isEditorEmpty(el) {
  return el.textContent.trim() === '' &&
         el.innerHTML.replace(/<br\s*\/?>/gi, '').trim() === '';
}

/* ─────────────────────────────────────────────
   LEGENDE: KLICK → TYP ÄNDERN
───────────────────────────────────────────── */
document.getElementById('legend').addEventListener('click', e => {
  const item = e.target.closest('.leg');
  if (!item) return;
  if (focused) {
    setType(focused, item.dataset.type);
    // Fokus zurück auf den Block setzen (wird durch blur-Verzögerung ggf. verloren)
    setTimeout(() => { if (focused) focusBlock(focused); }, 90);
  } else {
    showToast('Zuerst einen Block durch Klicken auswählen');
  }
});

/* ─────────────────────────────────────────────
   AKTIONS-BUTTONS
───────────────────────────────────────────── */
document.getElementById('btn-add').addEventListener('click', () => {
  const nb = insertBlock('normal', '', focused);
  focusBlock(nb);
});

document.getElementById('btn-print').addEventListener('click', () => {
  window.print();
});

/* ─────────────────────────────────────────────
   TOAST-MELDUNGEN
───────────────────────────────────────────── */
let toastTimer;
function showToast(msg) {
  toastEl.textContent = msg;
  toastEl.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => toastEl.classList.remove('show'), 1900);
}

/* ─────────────────────────────────────────────
   CURSOR ANS ENDE SETZEN
───────────────────────────────────────────── */
function caretToEnd(el) {
  el.focus();
  try {
    const range = document.createRange();
    range.selectNodeContents(el);
    range.collapse(false);
    const sel = window.getSelection();
    sel.removeAllRanges();
    sel.addRange(range);
  } catch (err) { /* ignore */ }
}

/* ─────────────────────────────────────────────
   INITIALISIERUNG
───────────────────────────────────────────── */
(function init() {

  syncToDoc();

  /* Beispiel-Inhalt beim ersten Start */
  const b1 = insertBlock('normal',
    'Notizen — Block anklicken, dann Typ per Alt+1/2/3 wählen oder in der Legende links klicken. Shift+Enter für Zeilenumbruch im Block.');

  const b2 = insertBlock('ayah',
    'قُلْ هُوَ اللَّهُ أَحَدٌ ۝ اللَّهُ الصَّمَدُ\n„Sag: Er ist Allah, der Einzige — Allah, der Beständige." (al-Ikhlāṣ 112:1–2)');

  const b3 = insertBlock('hadith',
    '«إِنَّمَا الأَعْمَالُ بِالنِّيَّاتِ»\n„Wahrlich, Taten werden nach den Absichten beurteilt." — Überliefert von ʿUmar ibn al-Khaṭṭāb (رضي الله عنه), gesammelt bei al-Bukhārī (Nr. 1).');

  const b4 = insertBlock('athaar',
    'Ibn Rajab al-Ḥanbalī (رحمه الله) sagte: „Das Fundament des Tawḥīd besteht darin, dass man Allah allein anbetet, ohne ihm einen Partner beizugesellen …"');

  const b5 = insertBlock('normal', '');

  // Leeren Block fokussieren
  requestAnimationFrame(() => focusBlock(b5));

})();
</script>
